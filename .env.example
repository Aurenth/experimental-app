# ============================================================
# Application Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Node environment: development | production | test
NODE_ENV=development

# API port
API_PORT=3000

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# Full DATABASE_URL for Prisma (used in apps/api)
DATABASE_URL=postgresql://appuser:apppassword@localhost:5432/appdb

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=app-uploads

# ============================================================
# JWT Authentication
# Generate secrets with: openssl rand -base64 64
# ============================================================
JWT_SECRET=change-me-use-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-use-a-different-openssl-rand-base64-64
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# CORS
# Comma-separated list of allowed origins
# ============================================================
CORS_ORIGIN=http://localhost:3001

# ============================================================
# Razorpay (payments)
# Get keys from https://dashboard.razorpay.com/app/keys
# Webhook secret from https://dashboard.razorpay.com/app/webhooks
# ============================================================
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME_with_webhook_secret

# ============================================================
# External Services (optional)
# ============================================================

# Firebase (push notifications) — fill when implementing push module
# FCM_SERVICE_ACCOUNT_JSON=

# Sentry (error tracking) — optional for local dev
# SENTRY_DSN=
